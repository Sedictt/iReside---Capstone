@startuml
!theme plain

skinparam backgroundColor #FEFEFE
skinparam packageStyle rectangle

' Actor styling
skinparam actor {
  BorderColor #2C3E50
  FontColor #2C3E50
  FontSize 14
  FontStyle bold
}

' Use case styling
skinparam usecase {
  BorderColor #34495E
  FontColor #2C3E50
  FontSize 12
  BackgroundColor #F8F9FA
}

' Arrow styling
skinparam arrow {
  Color #5D6D7E
  Thickness 1.5
}

' System boundary styling
skinparam rectangle {
  BorderColor #2980B9
  FontColor #2980B9
  FontSize 16
  FontStyle bold
  BackgroundColor #EBF5FB
}

' === ACTORS ===
actor Landlord as L
actor Tenant as T
actor Admin as A

' === SYSTEM BOUNDARY ===
rectangle "iReside System" {
  ' ----- LANDLORD USE CASES -----
  usecase "View Dashboard" as UC1
  usecase "Manage Properties" as UC2
  usecase "Manage Tenants" as UC3
  usecase "Create Leases" as UC4
  usecase "Track Maintenance" as UC5
  usecase "Review Applications" as UC6
  usecase "Send & Receive Messages" as UC7
  usecase "View Analytics" as UC8
  usecase "Generate Invoices" as UC9
  usecase "Capture Payments" as UC10
  usecase "Manage Documents" as UC11
  usecase "Configure Unit Map" as UC12
  usecase "Manage Utilities" as UC13
  usecase "Utility Billing" as UC14
  usecase "Process Move-Out" as UC15
  usecase "Manage Community" as UC16
  usecase "Manage Profile" as UC17
  usecase "Configure Settings" as UC18
  usecase "Manage Onboarding" as UC19

  ' ----- TENANT USE CASES -----
  usecase "Track Utilities" as UC20
  usecase "Submit Application" as UC21
  usecase "View Lease" as UC22
  usecase "Sign Lease" as UC23
  usecase "Request Maintenance" as UC24
  usecase "Make Payments" as UC25
  usecase "View Unit Map" as UC26
  usecase "Manage Profile" as UC27
  usecase "Configure Settings" as UC28
  usecase "View Community" as UC29

  ' ----- ADMIN USE CASES -----
  usecase "View System Dashboard" as UC30
  usecase "Manage Users" as UC31
  usecase "Review Registrations" as UC32
  usecase "Moderate Chat" as UC33
  usecase "Manage Consultation Tool" as UC34
  usecase "Verify System Integrity" as UC35
  usecase "Verify Business" as UC36

  ' ----- RELATIONSHIPS: INCLUDE / EXTEND -----
  UC23 .|> UC22 : <<extend>>
  UC32 ..> UC36 : <<include>>
}
' ============= END SYSTEM BOUNDARY =============

' ----- ASSOCIATIONS: LANDLORD -----
L --> UC1
L --> UC2
L --> UC3
L --> UC4
L --> UC5
L --> UC6
L --> UC7
L --> UC8
L --> UC9
L --> UC10
L --> UC11
L --> UC12
L --> UC13
L --> UC14
L --> UC15
L --> UC16
L --> UC17
L --> UC18
L --> UC19

' ----- ASSOCIATIONS: TENANT -----
T --> UC7
T --> UC20
T --> UC21
T --> UC22
T --> UC24
T --> UC25
T --> UC26
T --> UC27
T --> UC28
T --> UC29
T --> UC23

' ----- ASSOCIATIONS: ADMIN -----
A --> UC30
A --> UC31
A --> UC32
A --> UC33
A --> UC34
A --> UC35

@enduml
